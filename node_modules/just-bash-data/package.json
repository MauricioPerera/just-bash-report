{
  "name": "just-bash-data",
  "version": "1.1.2",
  "description": "just-bash plugin: db (MongoDB-style document store) and vec (vector similarity search) commands for in-shell agents.",
  "license": "MIT",
  "author": "Mauricio Perera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauricioPerera/just-bash-data.git"
  },
  "homepage": "https://github.com/MauricioPerera/just-bash-data#readme",
  "bugs": {
    "url": "https://github.com/MauricioPerera/just-bash-data/issues"
  },
  "keywords": [
    "just-bash",
    "llm-tools",
    "rag",
    "vector-search",
    "document-database",
    "mongodb-style",
    "jwt",
    "rbac",
    "encryption",
    "agent-shell"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "pnpm build && pnpm --filter just-bash-data-smoke smoke:full"
  },
  "dependencies": {
    "js-doc-store": "github:MauricioPerera/js-doc-store",
    "js-vector-store": "github:MauricioPerera/js-vector-store"
  },
  "peerDependencies": {
    "just-bash": ">=2.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "just-bash": "^2.14.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
